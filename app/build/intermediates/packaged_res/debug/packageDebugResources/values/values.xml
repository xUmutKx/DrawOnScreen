    <color name="on_primary">#000000</color>
    <color name="on_primary_container">#FFFFFF</color>
    <color name="on_secondary">#000000</color>
    <color name="on_surface">#FFFFFF</color>
    <color name="on_surface_dim">#888888</color>
    <color name="primary">#FFFFFF</color>
    <color name="primary_container">#1A1A1A</color>
    <color name="primary_dark">#CCCCCC</color>
    <color name="secondary">#AAAAAA</color>
    <color name="surface">#0D0D0D</color>
    <color name="surface_variant">#1A1A1A</color>
    <dimen name="pref_horizontal_padding">20dp</dimen>
    <dimen name="pref_icon_size">20dp</dimen>
    <dimen name="pref_row_height">56dp</dimen>
    <string name="app_name">Drawly</string>
    <string name="app_subtitle">Draw over any app</string>
    <string name="cancel">Cancel</string>
    <string name="channel_desc">Screen drawing overlay is active</string>
    <string name="channel_name">Drawing Service</string>
    <string name="close">Stop</string>
    <string name="grant_permission">Open Settings</string>
    <string name="notif_text">Drawing overlay is running</string>
    <string name="notif_title">Drawly Active</string>
    <string name="permission_denied">Permission denied. Enable it in Settings.</string>
    <string name="permission_message">Drawly needs "Display over other apps" permission. Tap Grant, enable the toggle, then return here.</string>
    <string name="permission_required">Permission Required</string>
    <string name="pref_auto_passthrough">Auto pass-through mode</string>
    <string name="pref_dark_overlay">Dark overlay layer</string>
    <string name="pref_finger_draw">Finger drawing</string>
    <string name="pref_keep_screen_on">Keep screen on</string>
    <string name="pref_minimal_ui">Minimal UI (hide toolbar)</string>
    <string name="pref_minimize_on_draw">Minimize on start</string>
    <string name="pref_pressure">Pressure sensitivity (stylus)</string>
    <string name="pref_show_eraser">Show eraser button</string>
    <string name="pref_show_laser">Show laser pointer</string>
    <string name="pref_show_passthrough">Show pass-through button</string>
    <string name="pref_show_redo">Show redo button</string>
    <string name="pref_show_screenshot">Show screenshot button</string>
    <string name="pref_show_shapes">Show shape buttons</string>
    <string name="pref_show_spotlight">Show spotlight</string>
    <string name="pref_show_undo">Show undo button</string>
    <string name="pref_smoothing">Stroke smoothing</string>
    <string name="pref_stylus_only">Stylus only mode</string>
    <string name="pref_toolbar_right">Toolbar on right side</string>
    <string name="pref_vibrate">Vibrate on start</string>
    <string name="section_drawing">Drawing</string>
    <string name="section_interface">Interface</string>
    <string name="section_toolbar">Toolbar</string>
    <string name="settings">Settings</string>
    <string name="start_drawing">Start Drawing</string>
    <string name="status_active">● Active</string>
    <string name="status_idle">● Idle</string>
    <string name="stop_drawing">Stop Drawing</string>
    <style name="PrefIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="tint">@color/on_surface_dim</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
    </style>
    <style name="PrefRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>
    <style name="PrefSwitch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="showText">false</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
    <style name="PrefTitle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">14sp</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
    </style>
    <style name="SectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/on_surface_dim</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">6dp</item>
    </style>
    <style name="Theme.DrawOnScreen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorError">#CF6679</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
    <style name="ToolButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="tint">@color/icon_tint</item>
        <item name="android:background">@drawable/bg_tool_button</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>
    <style name="ToolButtonAccent">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="tint">@color/icon_tint</item>
        <item name="android:background">@drawable/bg_tool_button_accent</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>
</resources>