<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbarRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_toolbar"
    android:padding="6dp"
    android:elevation="20dp">

    <!-- Drag Handle -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="32dp"
        android:layout_height="24dp"
        android:layout_gravity="center_horizontal"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <!-- Main Active Tool Display/Button -->
    <ImageButton
        android:id="@+id/btnToolSelect"
        style="@style/ToolButton"
        android:src="@drawable/ic_pen"
        android:contentDescription="Select Tool"
        android:background="@drawable/bg_tool_button"
        app:tint="#FFFFFF"/>

    <View android:layout_width="36dp" android:layout_height="1dp"
        android:background="@color/divider" android:layout_marginVertical="6dp"
        android:layout_gravity="center_horizontal"/>

    <ImageButton android:id="@+id/btnEraser"
        style="@style/ToolButton" android:src="@drawable/ic_eraser"
        app:tint="#FFFFFF"/>

    <ImageButton android:id="@+id/btnUndo"
        style="@style/ToolButton" android:src="@drawable/ic_undo"
        app:tint="#FFFFFF"/>

    <ImageButton android:id="@+id/btnClear"
        style="@style/ToolButton" android:src="@drawable/ic_delete"
        app:tint="#FF5252"/>

    <View android:layout_width="36dp" android:layout_height="1dp"
        android:background="@color/divider" android:layout_marginVertical="6dp"
        android:layout_gravity="center_horizontal"/>

    <ImageButton android:id="@+id/btnClose"
        style="@style/ToolButtonAccent" android:src="@drawable/ic_close"
        app:tint="#FFFFFF"/>

</LinearLayout>
