<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Settings"
        app:titleTextColor="#FFFFFF"
        android:background="#000000"
        app:navigationIconTint="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- INTERFACE -->
            <TextView style="@style/SectionHeader" android:text="Interface"/>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_settings"/>
                <TextView style="@style/PrefTitle" android:text="Minimal UI (Hide Toolbar)"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchMinimalUi"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_collapse"/>
                <TextView style="@style/PrefTitle" android:text="Minimize on start"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchMinimizeOnDraw"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_play"/>
                <TextView style="@style/PrefTitle" android:text="Keep screen on"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchKeepScreenOn"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_expand"/>
                <TextView style="@style/PrefTitle" android:text="Toolbar on right side"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchToolbarRight"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <!-- DRAWING ENGINE -->
            <TextView style="@style/SectionHeader" android:text="Drawing Engine"/>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_pen"/>
                <TextView style="@style/PrefTitle" android:text="Finger Drawing"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchFingerDraw"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_pencil"/>
                <TextView style="@style/PrefTitle" android:text="Stylus only mode"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchStylusOnly"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_brush"/>
                <TextView style="@style/PrefTitle" android:text="Line Smoothing (Bézier)"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchSmoothing"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_brush"/>
                <TextView style="@style/PrefTitle" android:text="Ink Bleeding Effect"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchInkBleeding"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_pen"/>
                <TextView style="@style/PrefTitle" android:text="Pressure Sensitivity"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchPressure"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <!-- TOOLS VISIBILITY -->
            <TextView style="@style/SectionHeader" android:text="Visible Tools"/>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_undo"/>
                <TextView style="@style/PrefTitle" android:text="Undo Button"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowUndo"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_redo"/>
                <TextView style="@style/PrefTitle" android:text="Redo Button"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowRedo"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_eraser"/>
                <TextView style="@style/PrefTitle" android:text="Eraser Tool"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowEraser"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_rect"/>
                <TextView style="@style/PrefTitle" android:text="Shape Tools"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowShapes"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_laser"/>
                <TextView style="@style/PrefTitle" android:text="Laser Pointer"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowLaser"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_spotlight"/>
                <TextView style="@style/PrefTitle" android:text="Spotlight Tool"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowSpotlight"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_line"/>
                <TextView style="@style/PrefTitle" android:text="Ruler Tool"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowRuler"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <!-- PENS -->
            <TextView style="@style/SectionHeader" android:text="Active Pens"/>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_fountain"/>
                <TextView style="@style/PrefTitle" android:text="Fountain Pen"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowFountain"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_calligraphy"/>
                <TextView style="@style/PrefTitle" android:text="Calligraphy Pen"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowCalligraphy"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_pencil"/>
                <TextView style="@style/PrefTitle" android:text="Sketch Pencil"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchShowPencil"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <!-- ADVANCED -->
            <TextView style="@style/SectionHeader" android:text="Advanced"/>

            <LinearLayout style="@style/PrefRow">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_check_circle"/>
                <TextView style="@style/PrefTitle" android:text="Hardware Acceleration"/>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHwAcceleration"
                    style="@style/PrefSwitch"/>
            </LinearLayout>

            <LinearLayout style="@style/PrefRow"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/rowResetAll">
                <ImageView style="@style/PrefIcon" android:src="@drawable/ic_delete" app:tint="#FF6B6B"/>
                <TextView style="@style/PrefTitle" android:text="Reset All Settings" android:textColor="#FF6B6B"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
